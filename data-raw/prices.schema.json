{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ellmer prices",
  "description": "Per-million-token pricing for LLM providers supported by ellmer",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["provider", "model", "variant"],
    "additionalProperties": false,
    "properties": {
      "provider": {
        "type": "string",
        "enum": [
          "Anthropic",
          "AWS/Bedrock",
          "Azure/OpenAI",
          "Google/Gemini",
          "Google/Vertex",
          "Groq",
          "Mistral",
          "OpenAI",
          "OpenRouter",
          "Posit"
        ]
      },
      "model": {
        "type": "string",
        "minLength": 1
      },
      "variant": {
        "type": "string"
      },
      "input": {
        "type": "number",
        "minimum": 0
      },
      "output": {
        "type": "number",
        "minimum": 0
      },
      "cached_input": {
        "type": "number",
        "minimum": 0
      }
    }
  }
}
